---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="500 Internal Server Error - Typing Speed Practice" description="An unexpected error occurred on the server of typing speed practice. Back to typing practice to test your WPM.">
  <div class="flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow flex items-center justify-center py-12">
      <div class="w-full max-w-md px-6 text-center font-sans">
        
        <!-- Error Code -->
        <h1 class="text-7xl font-extrabold tracking-tight text-ink font-mono mb-2">500</h1>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-6">internal server error.</h2>
        
        <!-- Description -->
        <p class="text-xs text-body leading-relaxed mb-8 max-w-sm mx-auto">
          An unexpected error occurred on our server. Please try reloading the page or check back later. Let's return to the typing test in the meantime.
        </p>

        <!-- Navigation Button -->
        <a 
          href="/" 
          class="inline-block rounded-sm bg-primary px-6 py-2.5 text-xs font-semibold text-on-primary shadow-sm hover:bg-primary/95 transition-all cursor-pointer"
        >
          Back to Practice
        </a>

      </div>
    </main>
    
    <Footer />
  </div>
</Layout>
