---
// TypingApp.astro
---

<div class="relative w-full max-w-(--size-breakpoint-xl) mx-auto px-6 py-12 z-10 font-sans">
  <!-- View 1: Core Typing Test -->
  <div id="test-view" class="w-full animate-in fade-in duration-300">
    <div class="flex flex-col lg:flex-row gap-8 items-start justify-center">
      <!-- Left Column Space -->
      <div class="hidden lg:block w-[160px] shrink-0 sticky top-24"></div>

      <!-- Center Core Workspace (Compact Width) -->
      <div class="flex-1 w-full max-w-[850px] space-y-8">
    
    <!-- Test Options Bar (Vercel stark panel style) -->
    <div class="flex flex-wrap items-center justify-between gap-4 rounded-sm border border-hairline bg-canvas p-3 shadow-[0_1px_2px_rgba(0,0,0,0.05)] transition-colors">
      <div class="flex items-center flex-wrap gap-x-4 gap-y-2 text-xs font-mono text-body">
        <!-- 1. Mode Specific Sub-options (First) -->
        <div id="sub-options-time" class="flex items-center border-r border-hairline pr-3 mr-1 gap-1">
          <span class="text-mute mr-1">time:</span>
          <button data-option-time="60" class="opt-btn active px-2 py-0.5 rounded-sm bg-canvas-soft-2 text-ink font-semibold cursor-pointer">1min</button>
          <button data-option-time="180" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">3min</button>
          <button data-option-time="300" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">5min</button>
        </div>

        <div id="sub-options-words" class="hidden flex items-center border-r border-hairline pr-3 mr-1 gap-1">
          <span class="text-mute mr-1">words:</span>
          <button data-option-words="10" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">10</button>
          <button data-option-words="25" class="opt-btn active px-2 py-0.5 rounded-sm bg-canvas-soft-2 text-ink font-semibold cursor-pointer">25</button>
          <button data-option-words="50" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">50</button>
          <button data-option-words="100" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">100</button>
        </div>

        <div id="sub-options-code" class="hidden flex items-center border-r border-hairline pr-3 mr-1 gap-1">
          <span class="text-mute mr-1">language:</span>
          <button data-option-code="javascript" class="opt-btn active px-2 py-0.5 rounded-sm bg-canvas-soft-2 text-ink font-semibold cursor-pointer">javascript</button>
          <button data-option-code="python" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">python</button>
          <button data-option-code="html" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">html</button>
        </div>

        <!-- 2. Test Mode Selectors (Middle) -->
        <div class="flex items-center border-r border-hairline pr-3 mr-1 gap-1">
          <span class="text-mute mr-1">mode:</span>
          <button data-option-mode="time" class="opt-btn active px-2 py-0.5 rounded-sm bg-canvas-soft-2 text-ink font-semibold cursor-pointer">time</button>
          <button data-option-mode="words" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">words</button>
          <button data-option-mode="code" class="opt-btn px-2 py-0.5 rounded-sm hover:bg-canvas-soft hover:text-ink cursor-pointer">code</button>
        </div>

        <!-- 3. Language Selector Dropdown (Last) -->
        <div id="sub-options-language" class="relative inline-block text-left">
          <div class="flex items-center gap-1.5">
            <span class="text-mute">language:</span>
            <div class="relative">
              <button 
                id="lang-dropdown-btn" 
                class="flex items-center gap-1.5 border border-hairline rounded-sm bg-canvas px-2.5 py-0.5 text-xs font-mono hover:bg-canvas-soft hover:text-ink cursor-pointer transition-colors"
                aria-expanded="false"
                aria-haspopup="true"
              >
                <span id="current-lang-label">english</span>
                <svg class="h-3 w-3 text-mute" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              
              <!-- Dropdown Menu -->
              <div 
                id="lang-dropdown-menu" 
                class="hidden absolute left-0 mt-1.5 w-28 rounded-sm border border-hairline bg-canvas shadow-lg z-30 font-mono text-xs divide-y divide-hairline transition-all duration-100"
              >
                <button data-option-lang="english" class="lang-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer bg-canvas-soft-2 font-semibold">english</button>
                <button data-option-lang="hindi" class="lang-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer">hindi</button>
                <button data-option-lang="spanish" class="lang-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer">spanish</button>
                <button data-option-lang="french" class="lang-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer">french</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Friction / Error Mode Dropdown -->
      <div class="flex items-center gap-1.5 text-xs font-mono text-body">
        <span class="text-mute">error handling:</span>
        <div class="relative inline-block text-left">
          <button 
            id="error-dropdown-btn" 
            class="flex items-center gap-1.5 border border-hairline rounded-sm bg-canvas px-2.5 py-0.5 text-xs font-mono hover:bg-canvas-soft hover:text-ink cursor-pointer transition-colors"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-link animate-pulse"></span>
            <span id="current-error-label">free mode</span>
            <svg class="h-3 w-3 text-mute" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- Dropdown Menu -->
          <div 
            id="error-dropdown-menu" 
            class="hidden absolute right-0 mt-1.5 w-28 rounded-sm border border-hairline bg-canvas shadow-lg z-30 font-mono text-xs divide-y divide-hairline transition-all duration-100"
          >
            <button data-option-error="free" class="error-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer bg-canvas-soft-2 font-semibold">free mode</button>
            <button data-option-error="strict" class="error-opt-btn w-full text-left px-3 py-1.5 hover:bg-canvas-soft text-body hover:text-ink cursor-pointer">strict mode</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Language Specific Tip (e.g. Hindi keyboard requirement) -->
    <div id="hindi-tip" class="hidden w-full items-center justify-between rounded-sm border border-link/25 bg-link-bg-soft/40 px-4 py-2 text-xs font-medium text-link shadow-sm">
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Tip: For Hindi mode, please ensure your OS Hindi Keyboard input (Inscript or Phonetic) is enabled.</span>
      </div>
    </div>

    <!-- Caps Lock Warning -->
    <div id="capslock-warning" class="hidden w-full items-center justify-between rounded-sm border border-warning-deep/20 bg-warning-soft px-4 py-2 text-xs font-medium text-warning-deep shadow-sm">
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <span>Caps Lock is active! Typing accuracy may be affected.</span>
      </div>
    </div>

    <!-- Active Test Section -->
    <div class="relative rounded-lg border border-hairline bg-canvas p-4 sm:p-8 shadow-[0_4px_12px_rgba(0,0,0,0.02),0_1px_2px_rgba(0,0,0,0.03)] overflow-hidden transition-colors">
      <!-- Faded atmospheric mesh gradient strictly constrained behind text -->
      <div class="mesh-container">
        <div class="mesh-glow-1"></div>
        <div class="mesh-glow-2"></div>
        <div class="mesh-glow-3"></div>
        <div class="mesh-glow-4"></div>
      </div>

      <!-- Hidden Input for keystrokes -->
      <input 
        type="text" 
        id="typing-input" 
        class="absolute -left-9999 top-0 opacity-0 -z-50 pointer-events-none" 
        autocomplete="off" 
        autocapitalize="off" 
        autocorrect="off" 
        spellcheck="false" 
      />

      <!-- Live metrics and stats during typing -->
      <div class="relative flex items-center justify-between mb-6 z-10">
        <div id="live-timer" class="font-mono text-3xl font-extrabold text-ink transition-all">
          60
        </div>
        <div class="flex items-center gap-6 font-mono text-xs text-mute">
          <div>wpm: <span id="live-wpm" class="text-ink font-semibold">0</span></div>
          <div>acc: <span id="live-acc" class="text-ink font-semibold">100%</span></div>
        </div>
      </div>

      <div 
        id="canvas-container" 
        class="relative min-h-[140px] max-h-[180px] overflow-hidden no-scrollbar z-10 select-none cursor-text pr-2"
      >
        <!-- Caret (Cursor) -->
        <div id="typing-caret" class="typing-caret"></div>

        <!-- Rendered Text Container -->
        <div 
          id="words-wrapper" 
          class="flex flex-wrap gap-x-2.5 gap-y-4 font-mono text-xl md:text-2xl leading-relaxed text-hairline-strong select-none tracking-normal transition-all duration-200 blur-sm"
        >
          <!-- Words will be injected here dynamically -->
        </div>
      </div>

      <!-- Start Test Prompt Overlay (with blur effect) -->
      <div id="start-overlay" class="absolute inset-0 bg-canvas/60 backdrop-blur-xs flex items-center justify-center cursor-pointer transition-all duration-300 z-20">
        <div class="flex items-center gap-2.5 rounded-sm border border-hairline bg-canvas px-4 py-2.5 text-xs font-semibold text-body shadow-md animate-pulse">
          <svg class="h-4 w-4 text-link" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
          </svg>
          <span>Press <kbd class="px-1.5 py-0.5 rounded-sm border border-hairline bg-canvas-soft-2 font-mono font-bold text-ink">Enter</kbd> to focus & start typing</span>
        </div>
      </div>

      <!-- Semi-transparent focus recovery overlay -->
      <div id="focus-overlay" class="absolute inset-0 bg-canvas/30 backdrop-blur-[0.5px] flex items-center justify-center cursor-pointer transition-opacity duration-200 z-20 hidden">
        <div class="flex items-center gap-2 rounded-sm border border-hairline bg-canvas px-4 py-2 text-xs font-medium text-body shadow-sm">
          <svg class="h-4 w-4 text-link" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
          </svg>
          <span>Click to focus typing area</span>
        </div>
      </div>

      <!-- Quick Reset Button -->
      <div class="relative flex justify-center mt-6 z-10">
        <button 
          id="reset-btn"
          title="Restart Test (Esc)"
          class="flex h-8 w-8 items-center justify-center rounded-sm border border-hairline text-mute hover:text-ink hover:bg-canvas-soft transition-colors cursor-pointer"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3m0 0l3 3m-3-3v8"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Quick Page Links (Outside and below the typing box) -->
    <div class="flex justify-center items-center gap-4 mt-4 text-[10px] font-mono uppercase tracking-wider text-mute z-10 relative">
      <a href="/about" class="hover:text-ink transition-all">About Us</a>
      <span class="text-hairline select-none">|</span>
      <a href="/privacy" class="hover:text-ink transition-all">Privacy Policy</a>
      <span class="text-hairline select-none">|</span>
      <a href="/terms" class="hover:text-ink transition-all">Terms & Conditions</a>
      <span class="text-hairline select-none">|</span>
      <a href="/contact" class="hover:text-ink transition-all">Contact Us</a>
    </div>

    <!-- Virtual Keyboard Card -->
    <div id="keyboard-container" class="hidden rounded-lg border border-hairline bg-canvas p-6 shadow-[0_1px_2px_rgba(0,0,0,0.05)] transition-all">
      <div class="flex items-center justify-between mb-4">
        <span class="font-mono text-[10px] text-mute uppercase tracking-wider">virtual keyboard map</span>
        <div class="flex items-center gap-4 text-[10px] font-mono text-mute">
          <span class="flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-link"></span> next key</span>
          <span class="flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-primary"></span> key down</span>
        </div>
      </div>

      <!-- The QWERTY Layout -->
      <div class="grid gap-1.5 max-w-2xl mx-auto font-mono text-xs select-none">
        <!-- Row 1 -->
        <div class="flex justify-between gap-1.5 w-full">
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-backquote">`</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-1">1</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-2">2</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-3">3</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-4">4</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-5">5</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-6">6</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-7">7</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-8">8</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-9">9</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-0">0</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-minus">-</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full grow" id="key-equal">=</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-14 text-[10px]" id="key-backspace">backspace</div>
        </div>

        <!-- Row 2 -->
        <div class="flex justify-between gap-1.5 w-full">
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-12 text-[10px]" id="key-tab">tab</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-q">q</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-w">w</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-e">e</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-r">r</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-t">t</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-y">y</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-u">u</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-i">i</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-o">o</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-p">p</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-bracketleft">[</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-bracketright">]</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-10" id="key-backslash">\</div>
        </div>

        <!-- Row 3 -->
        <div class="flex justify-between gap-1.5 w-full">
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-15 text-[10px]" id="key-capslock">caps</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-a">a</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-s">s</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-d">d</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-f">f</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-g">g</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-h">h</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-j">j</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-k">k</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-l">l</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-semicolon">;</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-quote">'</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-15 text-[10px]" id="key-enter">enter</div>
        </div>

        <!-- Row 4 -->
        <div class="flex justify-between gap-1.5 w-full">
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-18 text-[10px]" id="key-shiftleft">shift</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-z">z</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-x">x</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-c">c</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-v">v</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-b">b</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-n">n</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-m">m</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-comma">,</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-period">.</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-full" id="key-slash">/</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-18 text-[10px]" id="key-shiftright">shift</div>
        </div>

        <!-- Row 5 -->
        <div class="flex gap-1.5 w-full">
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-15 text-[10px]">ctrl</div>
          <div class="key rounded-sm border border-hairline bg-canvas-soft-2 text-body flex h-9.5 items-center justify-center w-12 text-[10px]">alt</div>
