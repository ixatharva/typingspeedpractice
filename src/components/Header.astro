---
// Header.astro
---

<header class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-(--size-breakpoint-xl) items-center justify-between px-6">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <!-- Minimalist Keyboard/Vercel Triangle SVG Logo -->
      <svg class="h-6 w-6 transition-transform duration-300 group-hover:rotate-12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L2 20H22L12 2Z" fill="#171717" />
        <rect x="7" y="14" width="2" height="2" fill="#ffffff" />
        <rect x="11" y="14" width="2" height="2" fill="#ffffff" />
        <rect x="15" y="14" width="2" height="2" fill="#ffffff" />
        <rect x="9" y="17" width="6" height="1.5" fill="#ffffff" />
      </svg>
      <span class="font-sans text-sm sm:text-lg font-semibold tracking-tight text-ink">
        typing speed <span class="text-body font-normal">practice.</span>
      </span>
    </a>

    <!-- Navigation Tabs -->
    <nav class="hidden md:flex items-center gap-1">
      <button 
        data-tab="test" 
        class="nav-tab active px-3 py-1.5 text-sm font-medium rounded-pill transition-colors duration-200 text-ink bg-canvas-soft-2 hover:text-ink cursor-pointer"
      >
        Test
      </button>
      <button 
        data-tab="stats" 
        class="nav-tab px-3 py-1.5 text-sm font-medium rounded-pill transition-colors duration-200 text-body hover:text-ink hover:bg-canvas-soft-2/60 cursor-pointer"
      >
        Stats
      </button>
    </nav>

    <!-- CTAs and Links -->
    <div class="flex items-center gap-3">
      <!-- Collapsible Keyboard Toggle (Indicator) -->
      <button 
        id="keyboard-toggle" 
        title="Toggle Keyboard Visiblity"
        class="hidden md:flex h-8 items-center gap-1.5 rounded-sm border border-hairline px-2.5 text-xs font-mono text-body hover:text-ink hover:bg-canvas-soft transition-colors cursor-pointer"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2" ry="2" />
          <line x1="6" y1="8" x2="6" y2="8" />
          <line x1="10" y1="8" x2="10" y2="8" />
          <line x1="14" y1="8" x2="14" y2="8" />
          <line x1="18" y1="8" x2="18" y2="8" />
          <line x1="6" y1="12" x2="6" y2="12" />
          <line x1="18" y1="12" x2="18" y2="12" />
          <line x1="7" y1="16" x2="17" y2="16" />
          <line x1="10" y1="12" x2="14" y2="12" />
        </svg>
        <span>keyboard</span>
      </button>

      <!-- Theme Switcher Button -->
      <button 
        id="theme-toggle" 
        title="Toggle Light/Dark Theme"
        class="flex h-8 w-8 items-center justify-center rounded-sm border border-hairline text-body hover:text-ink hover:bg-canvas-soft transition-colors cursor-pointer"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg id="theme-sun" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg id="theme-moon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- Vercel-style signup button -->
      <button 
        id="reset-btn-header"
        class="flex items-center gap-1.5 rounded-sm bg-primary px-3 py-1 text-xs font-semibold text-on-primary transition-all hover:bg-primary/95 cursor-pointer"
      >
        <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"></path>
        </svg>
        <span>Reset</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Simple navigation listener that communicates with the main TypingApp component via DOM events
  const tabs = document.querySelectorAll('.nav-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-canvas-soft-2', 'text-ink');
        t.classList.add('text-body');
        t.classList.remove('bg-canvas-soft-2/60');
      });
      tab.classList.add('active', 'bg-canvas-soft-2', 'text-ink');
      tab.classList.remove('text-body');

      const targetTab = tab.getAttribute('data-tab');
      // Dispatch custom event to let components switch views
      document.dispatchEvent(new CustomEvent('switch-tab', { detail: { tab: targetTab } }));
    });
  });

  // Listener to switch tabs from external source
  document.addEventListener('set-active-tab', (e: any) => {
    const activeTab = e.detail.tab;
    tabs.forEach(t => {
      const isTarget = t.getAttribute('data-tab') === activeTab;
      if (isTarget) {
        t.classList.add('active', 'bg-canvas-soft-2', 'text-ink');
        t.classList.remove('text-body');
      } else {
        t.classList.remove('active', 'bg-canvas-soft-2', 'text-ink');
        t.classList.add('text-body');
      }
    });
  });

  // Setup simple button hooks
  document.getElementById('keyboard-toggle')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('toggle-keyboard'));
  });

  document.getElementById('reset-btn-header')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('reset-typing-test'));
  });

  // Theme Toggle logic
  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('theme-sun');
  const moonIcon = document.getElementById('theme-moon');

  // Initialize theme from localStorage or default to system preference
  const savedTheme = localStorage.getItem('theme');
  const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const isDark = savedTheme === 'dark' || (!savedTheme && systemPrefersDark);

  if (isDark) {
    document.documentElement.classList.add('dark');
    sunIcon?.classList.remove('hidden');
    moonIcon?.classList.add('hidden');
  } else {
    document.documentElement.classList.remove('dark');
    sunIcon?.classList.add('hidden');
    moonIcon?.classList.remove('hidden');
  }

  themeToggle?.addEventListener('click', () => {
    const isNowDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isNowDark ? 'dark' : 'light');
    
    if (isNowDark) {
      sunIcon?.classList.remove('hidden');
      moonIcon?.classList.add('hidden');
    } else {
      sunIcon?.classList.add('hidden');
      moonIcon?.classList.remove('hidden');
    }

    // Trigger an event to tell TypingApp to redraw or update if needed
    document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: isNowDark ? 'dark' : 'light' } }));
  });
</script>
