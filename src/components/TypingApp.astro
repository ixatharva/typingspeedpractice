          class="w-full sm:w-auto rounded-sm bg-primary px-5 py-2 text-xs font-semibold text-on-primary hover:bg-primary/95 transition-all cursor-pointer"
        >
          Try Again
        </button>
        <button 
          id="modal-btn-details"
          class="w-full sm:w-auto rounded-sm border border-hairline bg-canvas px-5 py-2 text-xs font-semibold text-ink hover:bg-canvas-soft transition-all cursor-pointer"
        >
          Show Details
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { multilingualWords } from '../utils/words.js';
  import { codeSnippets } from '../utils/code.js';

  // Constants & Core Configurations
  const KEY_MAP: Record<string, string> = {
    '`': 'key-backquote', '~': 'key-backquote',
    '1': 'key-1', '!': 'key-1',
    '2': 'key-2', '@': 'key-2',
    '3': 'key-3', '#': 'key-3',
    '4': 'key-4', '$': 'key-4',
    '5': 'key-5', '%': 'key-5',
    '6': 'key-6', '^': 'key-6',
    '7': 'key-7', '&': 'key-7',
    '8': 'key-8', '*': 'key-8',
    '9': 'key-9', '(': 'key-9',
    '0': 'key-0', ')': 'key-0',
    '-': 'key-minus', '_': 'key-minus',
    '=': 'key-equal', '+': 'key-equal',
    'backspace': 'key-backspace',
    'tab': 'key-tab',
    'q': 'key-q', 'w': 'key-w', 'e': 'key-e', 'r': 'key-r', 't': 'key-t', 'y': 'key-y', 'u': 'key-u', 'i': 'key-i', 'o': 'key-o', 'p': 'key-p',
    '[': 'key-bracketleft', '{': 'key-bracketleft',
    ']': 'key-bracketright', '}': 'key-bracketright',
    '\\': 'key-backslash', '|': 'key-backslash',
    'capslock': 'key-capslock',
    'a': 'key-a', 's': 'key-s', 'd': 'key-d', 'f': 'key-f', 'g': 'key-g', 'h': 'key-h', 'j': 'key-j', 'k': 'key-k', 'l': 'key-l',
    ';': 'key-semicolon', ':': 'key-semicolon',
    "'": 'key-quote', '"': 'key-quote',
    'enter': 'key-enter', '\n': 'key-enter',
    'shift': 'key-shiftleft',
    'z': 'key-z', 'x': 'key-x', 'c': 'key-c', 'v': 'key-v', 'b': 'key-b', 'n': 'key-n', 'm': 'key-m',
    ',': 'key-comma', '<': 'key-comma',
    '.': 'key-period', '>': 'key-period',
    '/': 'key-slash', '?': 'key-slash',
    ' ': 'key-space'
  };

  // State Management
  let currentMode = 'time'; // 'time' | 'words' | 'code'
  let currentProseLanguage = 'english'; // 'english' | 'hindi' | 'spanish' | 'french'
  let currentTimeLimit = 60; // seconds
  let currentWordsCount = 25; // count
  let currentLanguage = 'javascript'; // for code mode
  let isStrictErrorMode = false; // false (free mode) | true (strict mode)
  let isTestReady = false; // true when user pressed Enter or clicked overlay to focus
  
  let targetText = '';
  let lastLineTop = 0;
  let currentIndex = 0;
  let keystrokesCount = 0;
  let correctKeystrokesCount = 0;
  let incorrectKeystrokesCount = 0;
  let timerInterval: any = null;
  let isTestRunning = false;
  let isTestFinished = false;
  let secondsElapsed = 0;
  let testDuration = 0;
  
  // Real-time second-by-second analytics tracking
  interface ChartDataPoint {
    time: number;
    wpm: number;
    raw: number;
  }
  let chartStats: ChartDataPoint[] = [];

  // DOM Elements cache
  const typingInput = document.getElementById('typing-input') as HTMLInputElement;
  const wordsWrapper = document.getElementById('words-wrapper') as HTMLDivElement;
  const canvasContainer = document.getElementById('canvas-container') as HTMLDivElement;
  const caret = document.getElementById('typing-caret') as HTMLDivElement;
  const liveTimer = document.getElementById('live-timer') as HTMLDivElement;
  const liveWpm = document.getElementById('live-wpm') as HTMLSpanElement;
  const liveAcc = document.getElementById('live-acc') as HTMLSpanElement;
  const focusOverlay = document.getElementById('focus-overlay') as HTMLDivElement;
  const capslockWarning = document.getElementById('capslock-warning') as HTMLDivElement;
  const keyboardContainer = document.getElementById('keyboard-container') as HTMLDivElement;
  const hindiTip = document.getElementById('hindi-tip') as HTMLDivElement;
  const startOverlay = document.getElementById('start-overlay') as HTMLDivElement;

  // Prevent manual user scrolling on canvasContainer
  canvasContainer.addEventListener('wheel', (e) => e.preventDefault(), { passive: false });
  canvasContainer.addEventListener('touchmove', (e) => e.preventDefault(), { passive: false });

  // Language Dropdown elements
  const langDropdownBtn = document.getElementById('lang-dropdown-btn') as HTMLButtonElement;
  const langDropdownMenu = document.getElementById('lang-dropdown-menu') as HTMLDivElement;
  const currentLangLabel = document.getElementById('current-lang-label') as HTMLSpanElement;

  // Error Dropdown elements
  const errorDropdownBtn = document.getElementById('error-dropdown-btn') as HTMLButtonElement;
  const errorDropdownMenu = document.getElementById('error-dropdown-menu') as HTMLDivElement;
  const currentErrorLabel = document.getElementById('current-error-label') as HTMLSpanElement;
  
  // Time ended modal elements
  const timeEndedModal = document.getElementById('time-ended-modal') as HTMLDivElement;
  const modalWpm = document.getElementById('modal-wpm') as HTMLDivElement;
  const modalAcc = document.getElementById('modal-acc') as HTMLDivElement;
  const modalErrors = document.getElementById('modal-errors') as HTMLDivElement;
  const modalBtnRestart = document.getElementById('modal-btn-restart') as HTMLButtonElement;
  const modalBtnDetails = document.getElementById('modal-btn-details') as HTMLButtonElement;
  
  // Views
  const testView = document.getElementById('test-view') as HTMLDivElement;
  const statsView = document.getElementById('stats-view') as HTMLDivElement;
  const resultsContainer = document.getElementById('results-container') as HTMLDivElement;
  
  // Results Elements
  const resNetWpm = document.getElementById('res-net-wpm') as HTMLSpanElement;
  const resAccuracy = document.getElementById('res-accuracy') as HTMLSpanElement;
  const resRawWpm = document.getElementById('res-raw-wpm') as HTMLSpanElement;
  const resErrors = document.getElementById('res-errors') as HTMLSpanElement;
  const resultsModeInfo = document.getElementById('results-mode-info') as HTMLSpanElement;
  const chartRawPath = document.getElementById('chart-raw-path') as SVGPathElement;
  const chartNetPath = document.getElementById('chart-net-path') as SVGPathElement;
  
  // Option buttons
  const optButtons = document.querySelectorAll('.opt-btn');
  const toggleErrorModeBtn = document.getElementById('toggle-error-mode') as HTMLButtonElement;
  const errorModeText = document.getElementById('error-mode-text') as HTMLSpanElement;

  // Words/Letters selectors cache
  let letterSpans: NodeListOf<HTMLSpanElement>;

  // Initialize Game on Mount
  initTest();
  loadPersonalStats();

  // Core setup function
  function initTest() {
    clearInterval(timerInterval);
    isTestRunning = false;
    isTestFinished = false;
    isTestReady = false;
    currentIndex = 0;
    keystrokesCount = 0;
    correctKeystrokesCount = 0;
    incorrectKeystrokesCount = 0;
    secondsElapsed = 0;
    chartStats = [];
    typingInput.value = '';
    canvasContainer.scrollTop = 0;
    lastLineTop = 0;
    
    // UI elements update
    resultsContainer.classList.add('hidden');
    timeEndedModal.classList.add('hidden');
    liveWpm.innerText = '0';
    liveAcc.innerText = '100%';
    
    // Choose Text based on Mode
    generateTargetText();
    
    // Set timer initial Wording
    if (currentMode === 'time') {
      testDuration = currentTimeLimit;
      liveTimer.innerText = String(currentTimeLimit);
    } else {
      testDuration = 0;
      liveTimer.innerText = '0s';
    }

    renderWords();

    // Reset overlay and blur states
    startOverlay.classList.remove('hidden');
    wordsWrapper.classList.add('blur-sm');
    caret.style.display = 'none';

    // Show/hide Hindi tips banner
    if (currentProseLanguage === 'hindi' && currentMode !== 'code') {
      hindiTip.classList.remove('hidden');
      hindiTip.classList.add('flex');
    } else {
      hindiTip.classList.add('hidden');
      hindiTip.classList.remove('flex');
    }

    // Autofocus input so they can press Enter immediately
    setTimeout(() => {
      typingInput.focus();
    }, 50);

    // Highlight initial correct key
    highlightNextCorrectKey();
  }

  function generateTargetText() {
    if (currentMode === 'time' || currentMode === 'words') {
      const dictionary = multilingualWords[currentProseLanguage as keyof typeof multilingualWords] || multilingualWords.english;
      const count = currentMode === 'time' ? 100 : currentWordsCount; // generate plenty of words for time mode
      const selectedWords = [];
      for (let i = 0; i < count; i++) {
        const randIndex = Math.floor(Math.random() * dictionary.length);
        selectedWords.push(dictionary[randIndex]);
      }
      targetText = selectedWords.join(' ');
    } else if (currentMode === 'code') {
      const category = codeSnippets[currentLanguage as keyof typeof codeSnippets] || codeSnippets.javascript;
      const randIndex = Math.floor(Math.random() * category.length);
      targetText = category[randIndex];
    }
  }

  function renderWords() {
    wordsWrapper.innerHTML = '';
    
    // We split targetText into words, keeping whitespace/space representation
    // Let's render as spans. For code mode, spaces should not wrap weirdly.
    // In code mode, spaces can be normal or non-breaking, we preserve spaces and newlines!
    if (currentMode === 'code') {
      // Split by characters directly and represent lines
      let wordSpan = document.createElement('span');
      wordSpan.className = 'word flex flex-wrap gap-0';
      
      let charIdx = 0;
      for (let i = 0; i < targetText.length; i++) {
        const char = targetText[i];
        const span = document.createElement('span');
        span.className = 'letter untyped';
        span.dataset.charIdx = String(charIdx);
        
        if (char === ' ') {
          span.innerHTML = '&nbsp;';
        } else if (char === '\n') {
          // New line support inside code wrapper
          span.innerHTML = '↵';
          span.classList.add('w-full', 'block', 'h-0', 'invisible');
        } else {
          span.innerText = char;
        }
        wordSpan.appendChild(span);
        charIdx++;
      }
      wordsWrapper.appendChild(wordSpan);
    } else {
      // Standard Words separation
      const words = targetText.split(' ');
      let charIdx = 0;
      words.forEach((word, wIdx) => {
        const wordSpan = document.createElement('span');
        wordSpan.className = 'word flex';
        wordSpan.dataset.wordIdx = String(wIdx);

        for (let i = 0; i < word.length; i++) {
          const span = document.createElement('span');
          span.className = 'letter untyped';
          span.innerText = word[i];
          span.dataset.charIdx = String(charIdx);
          wordSpan.appendChild(span);
          charIdx++;
        }

        // Add space at the end of word (if not last word)
        if (wIdx < words.length - 1) {
          const spaceSpan = document.createElement('span');
          spaceSpan.className = 'letter untyped border-b border-transparent';
          spaceSpan.innerHTML = '&nbsp;'; // Non-breaking space
          spaceSpan.dataset.charIdx = String(charIdx);
          wordSpan.appendChild(spaceSpan);
          charIdx++;
        }

        wordsWrapper.appendChild(wordSpan);
      });
    }

    letterSpans = wordsWrapper.querySelectorAll('.letter');
    
    // Position initial caret position
    setTimeout(updateCaret, 20);
  }

  function updateCaret() {
    if (isTestFinished) return;
    const activeLetter = letterSpans[currentIndex];
    
    if (activeLetter) {
      caret.style.display = 'block';
      
      // Calculate top/left matching letter coordinates
      caret.style.left = `${activeLetter.offsetLeft}px`;
      caret.style.top = `${activeLetter.offsetTop}px`;
      caret.style.height = `${activeLetter.offsetHeight}px`;
      
      // Keep caret active/solid style
      caret.classList.add('typing-active');
      
      // Auto-scrolling: keep the active line as the second line in the viewport when the line changes
      const letterTop = activeLetter.offsetTop;
      if (letterTop !== lastLineTop) {
        const lineHeight = activeLetter.offsetHeight || 36;
        const targetScrollTop = letterTop - lineHeight;
        canvasContainer.scrollTop = Math.max(0, targetScrollTop);
        lastLineTop = letterTop;
      }
      
      // Clear key indicators
      clearNextKeyIndicator();
      highlightNextCorrectKey();
    } else {
      // caret reaches end of text
      const lastLetter = letterSpans[letterSpans.length - 1];
      if (lastLetter) {
        caret.style.left = `${lastLetter.offsetLeft + lastLetter.offsetWidth}px`;
        caret.style.top = `${lastLetter.offsetTop}px`;
      }
      clearNextKeyIndicator();
    }
  }

  // Next expected key indicator on the virtual keyboard (For Hindi, keys fall back or match IME)
  function highlightNextCorrectKey() {
    const activeLetter = letterSpans[currentIndex];
    if (!activeLetter) return;
    
    let keyChar = activeLetter.innerText.toLowerCase();
    if (activeLetter.innerHTML === '&nbsp;') {
      keyChar = ' ';
    }
    
    const keyId = KEY_MAP[keyChar];
    if (keyId) {
      const keyElem = document.getElementById(keyId);
      if (keyElem) {
        keyElem.classList.add('border-link', 'text-link', 'bg-link/5');
      }
    }
  }

  function clearNextKeyIndicator() {
    document.querySelectorAll('.key').forEach(el => {
      el.classList.remove('border-link', 'text-link', 'bg-link/5');
    });
  }

  // Live performance stats calculation
  function recalculateMetrics() {
    if (keystrokesCount === 0) return;
    
    // Accuracy = (correct keys / total keystrokes) * 100
    const currentAccuracy = Math.max(0, Math.min(100, (correctKeystrokesCount / keystrokesCount) * 100));
    liveAcc.innerText = `${currentAccuracy.toFixed(0)}%`;
    
    // WPM: standard is (correct characters / 5) / elapsed minutes
    const minutes = secondsElapsed > 0 ? secondsElapsed / 60 : 0;
    if (minutes > 0) {
      // Calculate Net WPM
      const netWpm = Math.round((correctKeystrokesCount / 5) / minutes);
      liveWpm.innerText = String(netWpm);
    }
  }

  function startTestFocus() {
    isTestReady = true;
    startOverlay.classList.add('hidden');
    wordsWrapper.classList.remove('blur-sm');
    caret.style.display = 'block';
    updateCaret();
    typingInput.focus();
  }

  // Core Keydown Handler
  function handleKeyDown(e: KeyboardEvent) {
    if (isTestFinished) return;
    
    // Intercept Enter key to start the test
    if (!isTestReady) {
      if (e.key === 'Enter') {
        startTestFocus();
      }
      return;
    }
    
    // Prevent standard scroll keys when focused
    if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", "Tab"].includes(e.code) && document.activeElement === typingInput) {
      e.preventDefault();
    }

    // Tab resets test directly
    if (e.key === 'Tab') {
      initTest();
      return;
    }

    // Escape resets test
    if (e.key === 'Escape') {
      initTest();
      return;
    }

    // Detect Caps Lock status
    if (e.getModifierState && e.getModifierState('CapsLock')) {
      capslockWarning.classList.remove('hidden');
      capslockWarning.classList.add('flex');
    } else {
      capslockWarning.classList.add('hidden');
      capslockWarning.classList.remove('flex');
    }

    // Virtual keyboard button press indicator
    const pressedKeyId = KEY_MAP[e.key.toLowerCase()];
    if (pressedKeyId) {
      const keyElem = document.getElementById(pressedKeyId);
      if (keyElem) {
        keyElem.classList.add('bg-primary', 'text-on-primary', 'border-primary');
      }
    }

    // Shift Key indicator highlights shiftleft/shiftright keys
    if (e.key === 'Shift') {
      const side = e.location === 1 ? 'key-shiftleft' : 'key-shiftright';
      const keyElem = document.getElementById(side);
      if (keyElem) {
        keyElem.classList.add('bg-primary', 'text-on-primary', 'border-primary');
      }
    }

    // Main text input logic
    if (e.key === 'Backspace') {
      if (currentIndex > 0) {
        currentIndex--;
        const currentLetter = letterSpans[currentIndex];
        
        // Update states back to untyped
        currentLetter.classList.remove('correct', 'incorrect', 'extra');
        currentLetter.classList.add('untyped');
        
        // Recalculate keystrokes
        if (correctKeystrokesCount > 0 && currentLetter.dataset.wasCorrect === 'true') {
          correctKeystrokesCount--;
        }
        
        updateCaret();
        recalculateMetrics();
      }
      return;
    }

    // We process characters (letters, spaces, special syntax)
    if (e.key.length === 1) {
      // Start test timer on first typing stroke
      if (!isTestRunning) {
        startTestTimer();
      }

      keystrokesCount++;
      const currentLetter = letterSpans[currentIndex];
      
      if (!currentLetter) return;

      let expectedChar = currentLetter.innerText;
      // Convert NBSP representation
      if (currentLetter.innerHTML === '&nbsp;') {
        expectedChar = ' ';
      }
      
      const typedChar = e.key;

      if (typedChar === expectedChar) {
        // Correct Input
        currentLetter.classList.remove('untyped', 'incorrect');
        currentLetter.classList.add('correct');
        currentLetter.dataset.wasCorrect = 'true';
        correctKeystrokesCount++;
        currentIndex++;
      } else {
        // Incorrect Input (Friction / Error)
        incorrectKeystrokesCount++;
        currentLetter.classList.remove('untyped');
        currentLetter.classList.add('incorrect');
        currentLetter.dataset.wasCorrect = 'false';

        // Error handling behavior
        if (isStrictErrorMode) {
          // Strict: stop cursor forward progress, highlight red
          // We do not increment currentIndex. Caret stays at current letter!
          // Soft screen shake feedback
          wordsWrapper.classList.add('animate-shake');
          setTimeout(() => wordsWrapper.classList.remove('animate-shake'), 150);
        } else {
          // Free mode: highlight red but continue
          currentIndex++;
        }
      }

      updateCaret();
      recalculateMetrics();
      
      // If we finished all letters in words mode or code mode, trigger end
      if (currentIndex >= letterSpans.length) {
        finishTest();
      }
    }
  }

  function handleKeyUp(e: KeyboardEvent) {
    // Clear pressed key background
    const pressedKeyId = KEY_MAP[e.key.toLowerCase()];
    if (pressedKeyId) {
      const keyElem = document.getElementById(pressedKeyId);
      if (keyElem) {
        keyElem.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
      }
    }
    
    if (e.key === 'Shift') {
      document.getElementById('key-shiftleft')?.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
      document.getElementById('key-shiftright')?.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
    }

    // Caret blink resumes on inactivity
    caret.classList.remove('typing-active');
  }

  // Timer functions
  function startTestTimer() {
    isTestRunning = true;
    secondsElapsed = 0;
    
    // Fade out navigation controls for clean focus
    document.querySelector('header')?.classList.add('opacity-10', 'transition-opacity', 'duration-500');
    document.querySelector('footer')?.classList.add('opacity-10', 'transition-opacity', 'duration-500');

    timerInterval = setInterval(() => {
      secondsElapsed++;
      
      if (currentMode === 'time') {
        const remaining = currentTimeLimit - secondsElapsed;
        liveTimer.innerText = String(remaining);
        
        // Track second metrics for line chart
        recordSecondStats();

        if (remaining <= 0) {
          finishTest();
        }
      } else {
        liveTimer.innerText = `${secondsElapsed}s`;
        recordSecondStats();
      }
    }, 1000);
  }

  function recordSecondStats() {
    const minutes = secondsElapsed / 60;
    const currentNet = minutes > 0 ? Math.round((correctKeystrokesCount / 5) / minutes) : 0;
    const currentRaw = minutes > 0 ? Math.round((keystrokesCount / 5) / minutes) : 0;
    chartStats.push({
      time: secondsElapsed,
      wpm: currentNet,
      raw: currentRaw
    });
  }

  function finishTest() {
    clearInterval(timerInterval);
    isTestRunning = false;
    isTestFinished = true;
    
    // Restore layout transparency
    document.querySelector('header')?.classList.remove('opacity-10');
    document.querySelector('footer')?.classList.remove('opacity-10');
    
    // Make sure we have at least one data point
    if (chartStats.length === 0) {
      recordSecondStats();
    }
    
    caret.style.display = 'none';
    
    // Show results
    showResults();
  }

  // SVG Chart Painter (Pure vanilla rendering)
  function renderSVGChart() {
    if (chartStats.length === 0) return;
    
    const chartWidth = 600;
    const chartHeight = 150;
    
    // Find limits
    const maxWpm = Math.max(...chartStats.map(d => d.raw), 60); // min ceiling is 60 WPM
    const totalDuration = chartStats.length;
    
    // Draw raw wpm path
    let rawPathD = '';
    let netPathD = '';
    
    chartStats.forEach((pt, idx) => {
      const x = (idx / (totalDuration - 1)) * chartWidth;
      const yRaw = chartHeight - (pt.raw / maxWpm) * (chartHeight - 20) - 10;
      const yNet = chartHeight - (pt.wpm / maxWpm) * (chartHeight - 20) - 10;
      
      if (idx === 0) {
        rawPathD = `M ${x} ${yRaw}`;
        netPathD = `M ${x} ${yNet}`;
      } else {
        rawPathD += ` L ${x} ${yRaw}`;
        netPathD += ` L ${x} ${yNet}`;
      }
    });
    
    chartRawPath.setAttribute('d', rawPathD);
    chartNetPath.setAttribute('d', netPathD);
  }

  function showResults() {
    const elapsedMinutes = secondsElapsed > 0 ? secondsElapsed / 60 : currentTimeLimit / 60;
    
    // Math indicators
    const finalNetWpm = Math.round((correctKeystrokesCount / 5) / elapsedMinutes);
    const finalRawWpm = Math.round((keystrokesCount / 5) / elapsedMinutes);
    const finalAccuracy = Math.max(0, Math.min(100, (correctKeystrokesCount / keystrokesCount) * 100));
    
    resNetWpm.innerText = String(finalNetWpm);
    resAccuracy.innerText = `${finalAccuracy.toFixed(1)}`;
    resRawWpm.innerText = String(finalRawWpm);
    resErrors.innerText = String(incorrectKeystrokesCount);
    
    const modeInfo = currentMode === 'time' 
      ? `Time Mode (${currentTimeLimit}s)` 
      : currentMode === 'words' 
        ? `Words Mode (${currentWordsCount})` 
        : `Code Mode (${currentLanguage})`;
    resultsModeInfo.innerText = modeInfo;

    // Render Vercel Receipt JSON
    const receiptData = {
      domain: "typingspeedpractice.com",
      timestamp: new Date().toISOString(),
      performance: {
        net_wpm: finalNetWpm,
        raw_wpm: finalRawWpm,
        accuracy_percent: Number(finalAccuracy.toFixed(1)),
        keystrokes: {
          total: keystrokesCount,
          correct: correctKeystrokesCount,
          incorrect: incorrectKeystrokesCount
        }
      },
      settings: {
        mode: currentMode,
        options: currentMode === 'time' ? `${currentTimeLimit}s` : currentMode === 'words' ? currentWordsCount : currentLanguage,
        error_handling: isStrictErrorMode ? "strict (stop on error)" : "free (highlight error)"
      }
    };
    
    // Draw SVG
    renderSVGChart();
    
    // Toggle Results Screen display
    resultsContainer.classList.remove('hidden');

    // Populate and show the popup modal
    modalWpm.innerText = String(finalNetWpm);
    modalAcc.innerText = `${finalAccuracy.toFixed(1)}%`;
    modalErrors.innerText = String(incorrectKeystrokesCount);
    timeEndedModal.classList.remove('hidden');
    
    // Save to local stats
    saveSessionStats(finalNetWpm, finalAccuracy, incorrectKeystrokesCount);
  }

  // Local Storage Data saving & rendering
  function saveSessionStats(wpm: number, accuracy: number, errors: number) {
    const history = JSON.parse(localStorage.getItem('typing_stats_history') || '[]');
    const newSession = {
      date: new Date().toLocaleDateString() + ' ' + new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}),
      mode: currentMode,
      wpm: wpm,
      accuracy: Math.round(accuracy),
      errors: errors,
      style: isStrictErrorMode ? 'strict' : 'free'
    };
    
    history.unshift(newSession);
    localStorage.setItem('typing_stats_history', JSON.stringify(history.slice(0, 15))); // Cap at 15 sessions log
    
    // Reload personal stats view
    loadPersonalStats();
  }

  function loadPersonalStats() {
    const history = JSON.parse(localStorage.getItem('typing_stats_history') || '[]');
    const statsLogRows = document.getElementById('stats-log-rows') as HTMLTableSectionElement;
    const noStatsPlaceholder = document.getElementById('no-stats-placeholder') as HTMLDivElement;
    
    if (history.length === 0) {
      noStatsPlaceholder.classList.remove('hidden');
      statsLogRows.innerHTML = '';
      
      document.getElementById('pb-time-speed')!.innerText = '0';
      document.getElementById('pb-words-speed')!.innerText = '0';
      document.getElementById('pb-avg-accuracy')!.innerText = '0';
      return;
    }
    
    noStatsPlaceholder.classList.add('hidden');
    statsLogRows.innerHTML = '';
    
    let bestTimeSpeed = 0;
    let bestWordsSpeed = 0;
    let totalAccSum = 0;
    
    history.forEach((session: any) => {
      const tr = document.createElement('tr');
      tr.className = 'border-b border-hairline hover:bg-canvas-soft';
      
      tr.innerHTML = `
        <td class="p-3 text-mute">${session.date}</td>
        <td class="p-3 font-semibold">${session.mode}</td>
        <td class="p-3 text-ink">${session.wpm}</td>
        <td class="p-3 text-ink">${session.accuracy}%</td>
        <td class="p-3 text-error">${session.errors}</td>
        <td class="p-3"><span class="px-1.5 py-0.5 rounded-xs text-[10px] ${session.style === 'strict' ? 'bg-error-soft text-error-deep' : 'bg-link-bg-soft text-link'}">${session.style}</span></td>
      `;
      statsLogRows.appendChild(tr);
      
      // Calculate Personal best items
      if (session.mode === 'time' && session.wpm > bestTimeSpeed) {
        bestTimeSpeed = session.wpm;
      }
      if (session.mode === 'words' && session.wpm > bestWordsSpeed) {
        bestWordsSpeed = session.wpm;
      }
      totalAccSum += session.accuracy;
    });
    
    document.getElementById('pb-time-speed')!.innerText = String(bestTimeSpeed);
    document.getElementById('pb-words-speed')!.innerText = String(bestWordsSpeed);
    document.getElementById('pb-avg-accuracy')!.innerText = String(Math.round(totalAccSum / history.length));
  }

  // Interactivity Actions listeners
  typingInput.addEventListener('keydown', handleKeyDown);
  typingInput.addEventListener('keyup', handleKeyUp);
  
  startOverlay.addEventListener('click', () => {
    startTestFocus();
  });

  focusOverlay.addEventListener('click', () => {
    typingInput.focus();
  });
  
  wordsWrapper.addEventListener('click', () => {
    if (isTestReady) {
      typingInput.focus();
    } else {
      startTestFocus();
    }
  });

  document.getElementById('canvas-container')?.addEventListener('click', () => {
    if (isTestReady) {
      typingInput.focus();
    } else {
      startTestFocus();
    }
  });

  // Toggle visual overlay based on focus states
  typingInput.addEventListener('focus', () => {
    if (isTestReady) {
      focusOverlay.classList.add('hidden');
    }
  });

  typingInput.addEventListener('blur', () => {
    if (!isTestFinished && isTestReady) {
      focusOverlay.classList.remove('hidden');
    }
  });

  // Keep hidden input focused even during click events inside main box
  document.addEventListener('click', (e) => {
    const activeTestCard = document.querySelector('#test-view .relative.rounded-lg');
    if (activeTestCard && activeTestCard.contains(e.target as Node) && !isTestFinished) {
      typingInput.focus();
    }
  });

  // Header and buttons custom triggers listeners
  document.addEventListener('toggle-keyboard', () => {
    keyboardContainer.classList.toggle('hidden');
  });

  document.addEventListener('reset-typing-test', () => {
    initTest();
  });

  document.getElementById('reset-btn')?.addEventListener('click', initTest);
  document.getElementById('btn-restart-results')?.addEventListener('click', initTest);

  // Time ended modal actions
  modalBtnRestart?.addEventListener('click', () => {
    timeEndedModal.classList.add('hidden');
    initTest();
  });

  modalBtnDetails?.addEventListener('click', () => {
    timeEndedModal.classList.add('hidden');
    resultsContainer.scrollIntoView({ behavior: 'smooth' });
  });

  // Tab switcher
  document.addEventListener('switch-tab', (e: any) => {
    const targetTab = e.detail.tab;
    if (targetTab === 'test') {
      testView.classList.remove('hidden');
      statsView.classList.add('hidden');
      initTest();
    } else if (targetTab === 'stats') {
      testView.classList.add('hidden');
      statsView.classList.remove('hidden');
      loadPersonalStats();
    }
  });

  document.getElementById('btn-goto-stats')?.addEventListener('click', () => {
    testView.classList.add('hidden');
    statsView.classList.remove('hidden');
    loadPersonalStats();
    document.dispatchEvent(new CustomEvent('set-active-tab', { detail: { tab: 'stats' } }));
  });

  document.getElementById('btn-back-test')?.addEventListener('click', () => {
    statsView.classList.add('hidden');
    testView.classList.remove('hidden');
    initTest();
    document.dispatchEvent(new CustomEvent('set-active-tab', { detail: { tab: 'test' } }));
  });

  // Clear statistics handler
  document.getElementById('btn-clear-stats')?.addEventListener('click', () => {
    if (confirm('Are you sure you want to clear your typing statistics history?')) {
      localStorage.removeItem('typing_stats_history');
      loadPersonalStats();
    }
  });

  // Error Mode Dropdown toggles
  errorDropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = errorDropdownMenu.classList.toggle('hidden');
    errorDropdownBtn.setAttribute('aria-expanded', String(!isHidden));
  });

  // Options settings selector configuration
  optButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.parentElement;
      if (!parent) return;
      
      // Remove siblings active styles
      parent.querySelectorAll('.opt-btn').forEach(b => {
        b.classList.remove('active', 'bg-canvas-soft-2', 'text-ink', 'font-semibold');
        b.classList.add('hover:bg-canvas-soft', 'hover:text-ink');
      });
      
      // Add active state
      btn.classList.add('active', 'bg-canvas-soft-2', 'text-ink', 'font-semibold');
      btn.classList.remove('hover:bg-canvas-soft', 'hover:text-ink');
      
      // Handle Option settings changes
      const modeOpt = btn.getAttribute('data-option-mode');
      const timeOpt = btn.getAttribute('data-option-time');
      const wordsOpt = btn.getAttribute('data-option-words');
      const codeOpt = btn.getAttribute('data-option-code');
      const langOpt = btn.getAttribute('data-option-lang');
      
      if (modeOpt) {
        currentMode = modeOpt;
        
        // Hide sub-options
        document.getElementById('sub-options-time')?.classList.add('hidden');
        document.getElementById('sub-options-words')?.classList.add('hidden');
        document.getElementById('sub-options-code')?.classList.add('hidden');
        document.getElementById('sub-options-language')?.classList.add('hidden');
        
        if (currentMode === 'time') {
          document.getElementById('sub-options-time')?.classList.remove('hidden');
          document.getElementById('sub-options-language')?.classList.remove('hidden');
        } else if (currentMode === 'words') {
          document.getElementById('sub-options-words')?.classList.remove('hidden');
          document.getElementById('sub-options-language')?.classList.remove('hidden');
        } else if (currentMode === 'code') {
          document.getElementById('sub-options-code')?.classList.remove('hidden');
        }
      }
      
      if (timeOpt) {
        currentTimeLimit = Number(timeOpt);
      }
      
      if (wordsOpt) {
        currentWordsCount = Number(wordsOpt);
      }
      
      if (codeOpt) {
        currentLanguage = codeOpt;
      }

      // Reinitialize test
      initTest();
    });
  });

  // Language Dropdown toggles
  langDropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = langDropdownMenu.classList.toggle('hidden');
    langDropdownBtn.setAttribute('aria-expanded', String(!isHidden));
  });

  // Close dropdowns on click outside
  document.addEventListener('click', (e) => {
    // Language dropdown close
    if (langDropdownMenu && !langDropdownMenu.classList.contains('hidden')) {
      const isDropdownClick = langDropdownBtn.contains(e.target as Node) || langDropdownMenu.contains(e.target as Node);
      if (!isDropdownClick) {
        langDropdownMenu.classList.add('hidden');
        langDropdownBtn.setAttribute('aria-expanded', 'false');
      }
    }
    // Error dropdown close
    if (errorDropdownMenu && !errorDropdownMenu.classList.contains('hidden')) {
      const isDropdownClick = errorDropdownBtn.contains(e.target as Node) || errorDropdownMenu.contains(e.target as Node);
      if (!isDropdownClick) {
        errorDropdownMenu.classList.add('hidden');
        errorDropdownBtn.setAttribute('aria-expanded', 'false');
      }
    }
  });

  // Language options select handlers
  const langOptButtons = document.querySelectorAll('.lang-opt-btn');
  langOptButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-option-lang');
      if (lang) {
        currentProseLanguage = lang;
        currentLangLabel.innerText = lang;
        
        // Highlight active dropdown choice
        langOptButtons.forEach(b => {
          b.classList.remove('bg-canvas-soft-2', 'font-semibold');
          b.classList.add('hover:bg-canvas-soft');
        });
        btn.classList.add('bg-canvas-soft-2', 'font-semibold');
        btn.classList.remove('hover:bg-canvas-soft');
        
        // Close dropdown
        langDropdownMenu.classList.add('hidden');
        langDropdownBtn.setAttribute('aria-expanded', 'false');
        
        initTest();
      }
    });
  });

  // Error options select handlers
  const errorOptButtons = document.querySelectorAll('.error-opt-btn');
  errorOptButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.getAttribute('data-option-error');
      if (mode) {
        isStrictErrorMode = (mode === 'strict');
        currentErrorLabel.innerText = isStrictErrorMode ? 'strict mode' : 'free mode';
        
        // Highlight active dropdown choice
        errorOptButtons.forEach(b => {
          b.classList.remove('bg-canvas-soft-2', 'font-semibold');
          b.classList.add('hover:bg-canvas-soft');
        });
        btn.classList.add('bg-canvas-soft-2', 'font-semibold');
        btn.classList.remove('hover:bg-canvas-soft');

        // Update dot indicator color
        const dot = errorDropdownBtn.querySelector('span');
        if (dot) {
          if (isStrictErrorMode) {
            dot.classList.remove('bg-link');
            dot.classList.add('bg-error');
          } else {
            dot.classList.remove('bg-error');
            dot.classList.add('bg-link');
          }
        }
        
        // Close dropdown
        errorDropdownMenu.classList.add('hidden');
        errorDropdownBtn.setAttribute('aria-expanded', 'false');
        
        initTest();
      }
    });
  });
</script>

<!-- Add custom shakes on strict errors -->
<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }
  .animate-shake {
    animation: shake 0.15s ease-in-out;
  }
</style>
