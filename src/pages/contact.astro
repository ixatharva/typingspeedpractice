---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - Typing Speed Practice" description="Have questions, suggestions, or feature requests for typing speed practice? Contact us here through our clean messaging interface.">
  <div class="flex flex-col min-h-screen">
    <Header />
    
    <main class="flex-grow flex items-center justify-center py-12">
      <div class="w-full max-w-lg px-6 font-sans">
        
        <!-- Section Header -->
        <div class="border-b border-hairline pb-4 mb-8">
          <h1 class="text-2xl font-bold tracking-tight text-ink font-sans">Contact Us</h1>
          <p class="text-xs text-mute font-mono mt-1">SEND US A MESSAGE OR SHARE FEEDBACK</p>
        </div>

        <!-- Contact Form -->
        <form class="space-y-5" onsubmit="event.preventDefault(); alert('Thank you for reaching out! Form submissions are simulated for safety.');">
          <div class="space-y-1.5">
            <label for="contact-name" class="block text-[10px] font-mono uppercase tracking-wider text-mute">Your Name</label>
            <input 
              type="text" 
              id="contact-name" 
              required
              placeholder="Steve Jobs"
              class="w-full rounded-sm border border-hairline bg-canvas px-3 py-2 text-xs font-sans text-ink placeholder:text-mute focus:border-link focus:outline-none transition-colors"
            />
          </div>

          <div class="space-y-1.5">
            <label for="contact-email" class="block text-[10px] font-mono uppercase tracking-wider text-mute">Email Address</label>
            <input 
              type="email" 
              id="contact-email" 
              required
              placeholder="steve@apple.com"
              class="w-full rounded-sm border border-hairline bg-canvas px-3 py-2 text-xs font-sans text-ink placeholder:text-mute focus:border-link focus:outline-none transition-colors"
            />
          </div>

          <div class="space-y-1.5">
            <label for="contact-msg" class="block text-[10px] font-mono uppercase tracking-wider text-mute">Your Message</label>
            <textarea 
              id="contact-msg" 
              rows="5"
              required
              placeholder="What features or languages would you like to see added?"
              class="w-full rounded-sm border border-hairline bg-canvas px-3 py-2 text-xs font-sans text-ink placeholder:text-mute focus:border-link focus:outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full rounded-sm bg-primary py-2 text-xs font-semibold text-on-primary shadow-sm hover:bg-primary/95 transition-all cursor-pointer"
          >
            Send Message
          </button>
        </form>



      </div>
    </main>
    
    <Footer />
  </div>
</Layout>
